{
  "expo": {
    "name": "FastRoute",
    "slug": "fastroute-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "fastroute",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.oliverbill.fastroutemobile",
      "adaptiveIcon": {
        "backgroundColor": "#F3F4F6"
      }
    },
    "plugins": [
      "expo-document-picker",
      "expo-asset",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2937cf32-e16b-4af2-841a-583e048d998a"
      }
    },
    "owner": "oliverbill",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": false,
      "url": "https://u.expo.dev/2937cf32-e16b-4af2-841a-583e048d998a"
    }
  }
}
